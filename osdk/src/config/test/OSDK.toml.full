project_type = "kernel"

supported_archs = ["x86_64"]

[boot]
method = "grub-rescue-iso"
protocol = "multiboot2"

[run]
boot.kcmd_args = [
    "SHELL=/bin/sh",
    "LOGNAME=root",
    "HOME=/",
    "USER=root",
    "PATH=/bin:/benchmark",
    "init=/usr/bin/busybox",
]
boot.init_args = ["sh", "-l"]
boot.initramfs = "/tmp/osdk_test_file"

[test]
boot.method = "elf"

[grub]
display_grub_menu = true

[qemu]
args = """\
    -machine q35 \
    -smp $SMP \
    -m $MEM \
"""

[scheme."iommu"]
supported_archs = ["x86_64"]
qemu.args = """\
    -device intel-iommu,intremap=on,device-iotlb=on \
    -device ioh3420,id=pcie.0,chassis=1\
"""

[scheme."tdx"]
supported_archs = ["x86_64"]
build.features = ["cvm_guest"]
boot.method = "grub-qcow2"
boot.protocol = "linux-efi-handover64"
grub.grub_mkrescue = "/tmp/osdk_test_file"
qemu.path = "/tmp/osdk_test_file"
